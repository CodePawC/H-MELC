# —— 后端地址（二选一）
#
# 1）推荐本地开发：VITE_API_BASE_URL 保持空字符串，浏览器请求同源 /api/...，由 Vite 转发到下面 VITE_API_PROXY_TARGET（见 vite.config.ts，无 CORS 烦恼）。
# 2）浏览器直连后端：填写完整根地址（无尾部斜杠），例如 http://127.0.0.1:8010；须把该源加入后端 CORS_ORIGINS。
# 下面留空不是「没有后端」：开发时走同源 /api，由 Vite 转发到 VITE_API_PROXY_TARGET。
VITE_API_BASE_URL=

# 仅当 VITE_API_BASE_URL 为空时生效：dev 服务器把 /api、/screen-api 代理到此地址（与 docker-compose 后端默认 8000 一致）。
# 若你用 `uvicorn ... --port 8010`，改为 http://127.0.0.1:8010
VITE_API_PROXY_TARGET=http://127.0.0.1:8102

# 默认 false：JWT 走后端 POST /api/v1/auth/login；会话 GET /api/v1/auth/me。仅在离线演示时改为 true。
VITE_AUTH_MOCK=false

VITE_APP_NAME=H-MELC
VITE_APP_DISPLAY_NAME=医院医学装备全生命周期闭环管理平台
VITE_APP_SUBTITLE=申请论证 · 采购验收 · 建档使用 · 维修保养 · 计量监管 · 效益评价 · 报废处置

# 界面展示用版本号与改动流水号；每次交付/改动请递增 VITE_APP_BUILD_SERIAL
VITE_APP_VERSION=0.1.0
VITE_APP_BUILD_SERIAL=20260527.017

# 若统一网关返回「API Key invalid or missing」，向网关索取密钥后填写（与登录 JWT 可同时发送）
# VITE_API_KEY=
# VITE_API_KEY_HEADER=X-API-Key

# 本地走 Vite /api 代理时推荐：密钥只在 Node 转发时注入，不会进浏览器打包（与上二选一或并存均可）
# API_PROXY_GATEWAY_KEY=
# API_PROXY_GATEWAY_HEADER=X-API-Key
