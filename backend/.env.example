APP_NAME=H-MELC
APP_DISPLAY_NAME=医院医学装备全生命周期闭环管理平台
APP_ENV=development
SERVER_PORT=8102
FRONTEND_PORT=5102
UPLOAD_DIR=./storage/uploads
LOG_DIR=./storage/logs
BACKUP_DIR=./storage/backups

# 复制为 backend/.env 或仓库根 .env.local 后按需修改。
#
# —— 与本仓库 docker-compose.yml 一致（宿主机访问映射端口）
# Postgres: mep_user / mep_password，库名 mep
# 若使用本仓库 docker-compose.yml：默认将宿主 `5433` 映射到容器 5432（避免与本机已有 5432/HudMP 冲突），请将 URL 端口写为 5433。
# MinIO: MINIO_ROOT_USER / MINIO_ROOT_PASSWORD 与下行一致；桶名 mep-files（启动时如无则就绪检查会按需创建）。
# 本仓库 compose 将 MinIO API 映射到宿主 **9002**（控制台 9003），避免与已有 9000 冲突。

DATABASE_URL=postgresql+psycopg://mep_user:mep_password@127.0.0.1:5433/mep

# 本地直接 uvicorn 时可在 backend 目录执行一次：MEP_BOOTSTRAP_DEV_ADMIN=1 python scripts/docker_bootstrap.py（迁移 + 预置 admin；未设 MEP_DEV_ADMIN_PASSWORD 时默认口令为 admin123）。也可：`python scripts/create_identity_user.py admin admin123 SYS_ADMIN AUDIT_ADMIN DEVICE_ADMIN`。
# 使用 docker compose 启动后端镜像时会自动跑迁移；默认预置账号见 docker-compose.yml。

# —— 与其它项目（例如 HudMP）共用同一 Postgres 实例时
# 请单独 CREATE DATABASE mep，并让 DATABASE_URL 指向 mep。
# 不要复用对方业务库（如名为 hudmp 的数据库）：对方 Alembic 版本线与本期工程不一致会导致 upgrade head 报错。
# 示例（账号以对方 compose 为准）：
# DATABASE_URL=postgresql+psycopg://hudmp:hudmp@127.0.0.1:5432/mep

# 仅本地无 Postgres 或使用 SQLite 契约测试时使用（资产等迁移在非 PG 上不可用，勿对 SQLite 路径执行 alembic upgrade head）：
# DATABASE_URL=sqlite:///./local.db
#
# MDM 分类主数据（/api/v1/mdm/category-entries）仅支持 PostgreSQL；新库需在同一 DATABASE_URL 下执行 `alembic upgrade head`，含修订 e006_mdm_categories（mdm 模式与 category_entry 表）。
# AI 任务/结果与知识库文档（/api/v1/ai/*、/api/v1/knowledge/documents）需 e007_ai_knowledge（schema `ai`、`knowledge`）。
# Phase 0 单笔审批（/api/v1/workflows/start、/tasks/my、同意/驳回）需 e008_workflow_core（schema `workflow`）。
# 供应商门户（/api/v1/supplier-portal/*）与竞价 e010–e013；资质审核列 **e016**；发票/应付款 **e014**、**e015**。

# Redis 使用 compose 宿主映射时常见为 16379→6379。
REDIS_URL=redis://127.0.0.1:16379/0

MINIO_ENDPOINT=127.0.0.1:9002
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=mep-files
MINIO_SECURE=false

# —— 与其它 Compose（如 HudMP）共用 MinIO 时
# 使用对方定义的 ROOT 用户/密码，可能与上面默认值不同；MINIO_BUCKET 仍建议使用 mep-files 与本工程一致。
# MINIO_ACCESS_KEY=bme
# MINIO_SECRET_KEY=bme_dev_pwd_minio

CORS_ORIGINS=http://localhost:5102,http://127.0.0.1:5102,http://localhost:5173,http://127.0.0.1:5173

# JWT Phase 0（生产必须设置强随机密钥，勿用仓库默认值）
# JWT_SECRET_KEY=
# JWT_ACCESS_TOKEN_EXPIRE_MINUTES=720

# 主数据来源模式：local / remote / hybrid。默认 local，H-MELC 可独立部署运行。
MASTER_DATA_MODE=local

# 当 MASTER_DATA_MODE=remote 或 hybrid 时启用。H-MELC 只通过 Master Data Adapter 接入 H-UMDG。
UMDG_API_BASE_URL=
UMDG_API_TOKEN=
UMDG_TIMEOUT=5

# 本地缓存策略。hybrid 模式下 H-UMDG 不可用时可读取缓存或本地基础数据兜底。
MASTER_DATA_CACHE_ENABLED=true
MASTER_DATA_CACHE_TTL_SECONDS=3600

# 兼容旧配置名：历史内部集成模块曾使用 HMDM_*，新部署请使用 UMDG_*。
# HMDM_BASE_URL=
# HMDM_API_KEY=
