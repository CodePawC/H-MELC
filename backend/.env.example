APP_NAME=H-MELC
APP_DISPLAY_NAME=医院医学装备全生命周期闭环管理平台
APP_ENV=development
SERVER_PORT=8102
FRONTEND_PORT=5102
UPLOAD_DIR=./storage/uploads
LOG_DIR=./storage/logs
BACKUP_DIR=./storage/backups

# 复制为 backend/.env 后按需修改。标准命令 `cd backend && python -m uvicorn ...` 不会自动读取仓库根 .env.local。
#
# PostgreSQL 是硬性要求——本地开发必须启动 compose 或配置自己的 PG 实例。
# 标准命令：`docker compose up -d postgres` 然后 `cd backend && pytest -q`。
#
# 与本仓库 docker-compose.yml 一致（宿主机访问映射端口）：
# Postgres: mep_user / mep_password，库名 mep
# 本仓库 compose 将宿主 `5433` 映射到容器 5432（避免与本机已有 5432/HudMP 冲突）。
DATABASE_URL=postgresql+psycopg://mep_user:mep_password@127.0.0.1:5433/mep

# 首次启动 PostgreSQL 后，在 backend 目录执行一次 `alembic upgrade head` 创建所有表。
# 也可使用 `python scripts/docker_bootstrap.py`（等待 PostgreSQL + alembic upgrade head）。
# 如需同时预置开发账号，再临时设置 MEP_BOOTSTRAP_DEV_ADMIN=1；未设 MEP_DEV_ADMIN_PASSWORD 时默认口令为 admin123。
# 也可手工执行：`python scripts/create_identity_user.py admin admin123 SYS_ADMIN AUDIT_ADMIN DEVICE_ADMIN`。
# 使用 docker compose 启动后端镜像时会自动跑迁移；是否预置账号由 MEP_BOOTSTRAP_DEV_ADMIN 控制，默认见 docker-compose.yml。

# —— 与其它项目（例如 HudMP）共用同一 Postgres 实例时
# 请单独 CREATE DATABASE mep，并让 DATABASE_URL 指向 mep。
# 不要复用对方业务库（如名为 hudmp 的数据库）：对方 Alembic 版本线与本期工程不一致会导致 upgrade head 报错。
# 示例（账号以对方 compose 为准）：
# DATABASE_URL=postgresql+psycopg://hudmp:hudmp@127.0.0.1:5432/mep

# 可选依赖：Redis 和 MinIO。使用本仓库 docker-compose.yml 时取消注释以下行即可启用。
REDIS_URL=redis://127.0.0.1:16379/0
MINIO_ENDPOINT=127.0.0.1:9002
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=mep-files
MINIO_SECURE=false
# MINIO_REGION=

# —— 与其它 Compose（如 HudMP）共用 MinIO 时
# 使用对方定义的 ROOT 用户/密码，可能与上面默认值不同；MINIO_BUCKET 仍建议使用 mep-files 与本工程一致。
# MINIO_ACCESS_KEY=bme
# MINIO_SECRET_KEY=bme_dev_pwd_minio

# 当前管理端固定 5102，移动端固定 5175；仅浏览器直连后端时需要把对应前端源加入 CORS。
CORS_ORIGINS=http://localhost:5102,http://127.0.0.1:5102,http://localhost:5175,http://127.0.0.1:5175

# JWT Phase 0（生产必须设置强随机密钥，勿用仓库默认值）
# JWT_SECRET_KEY=
# JWT_ALGORITHM=HS256
# JWT_ACCESS_TOKEN_EXPIRE_MINUTES=720

# 主数据来源模式：local / remote / hybrid。remote 在后端代码中归一为 service；默认 hybrid，优先接入 H-UMDG，异常时使用缓存/本地兜底。
MASTER_DATA_MODE=hybrid
MASTER_DATA_PROVIDER=h-umdg
MASTER_DATA_BASE_URL=http://127.0.0.1:8101
MASTER_DATA_AUTH_TYPE=api_key
MASTER_DATA_API_KEY=hudmp-equipment-os-dev-20260525
MASTER_DATA_TIMEOUT=5000

# 当 MASTER_DATA_MODE=remote 或 hybrid 时启用。H-MELC 只通过 Master Data Adapter 接入 H-UMDG。
# 新部署优先使用 MASTER_DATA_BASE_URL / MASTER_DATA_API_KEY；下列 UMDG_* 为兼容旧配置名。
UMDG_API_BASE_URL=
UMDG_API_TOKEN=
UMDG_TIMEOUT=5

# 本地缓存和冲突策略。hybrid 模式下 H-UMDG 不可用时可读取缓存或本地基础数据兜底。
MASTER_DATA_CACHE_ENABLED=true
MASTER_DATA_CACHE_TTL=3600
MASTER_DATA_ALLOW_LOCAL_OVERRIDE=false
MASTER_DATA_ALLOW_TEMP_MAINTAIN=true
MASTER_DATA_CONFLICT_STRATEGY=standard_first
MASTER_DATA_QUALITY_CHECK_ENABLED=true
# 兼容旧配置名：
# MASTER_DATA_CACHE_TTL_SECONDS=3600

# 兼容更早期配置名：历史内部集成模块曾使用 HMDM_*，新部署请使用 MASTER_DATA_*。
# HMDM_BASE_URL=
# HMDM_API_KEY=