APP_NAME=H-MELC
APP_DISPLAY_NAME=医院医学装备全生命周期闭环管理平台
APP_ENV=development
SERVER_PORT=8102
FRONTEND_PORT=5102
DATABASE_URL=
UPLOAD_DIR=./storage/uploads
LOG_DIR=./storage/logs
BACKUP_DIR=./storage/backups

# 主数据来源模式：local / remote / hybrid
MASTER_DATA_MODE=local

# 当 MASTER_DATA_MODE=remote 或 hybrid 时启用
UMDG_API_BASE_URL=
UMDG_API_TOKEN=

# 本地缓存策略
MASTER_DATA_CACHE_ENABLED=true
MASTER_DATA_CACHE_TTL_SECONDS=3600

# Backend
REDIS_URL=redis://127.0.0.1:16379/0
CORS_ORIGINS=http://localhost:5102,http://127.0.0.1:5102

# Frontend
VITE_API_BASE_URL=
VITE_API_PROXY_TARGET=http://127.0.0.1:8102
VITE_AUTH_MOCK=false
VITE_APP_VERSION=0.1.0
VITE_APP_BUILD_SERIAL=20260527.017
